{
  "name": "@hostpay/sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for the HostPay payments API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "hostpay",
    "payments",
    "wallet",
    "mobile-money",
    "escrow",
    "sdk"
  ],
  "author": "HostPay <host.sl.co@gmail.com>",
  "license": "MIT",
  "homepage": "https://hpay.host-sl.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HOST-SL/hostpay-sdk.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/HOST-SL/hostpay-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-typescript ../openapi.json -o src/generated.ts",
    "pretest": "tsc",
    "test": "node --test",
    "check:version": "node -e \"const v=require('./package.json').version,s=require('fs').readFileSync('src/client.ts','utf8');if(!s.includes('hostpay-node/'+v)){console.error('src/client.ts User-Agent is stale: expected hostpay-node/'+v);process.exit(1)}\"",
    "prepublishOnly": "npm run check:version && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5"
  }
}