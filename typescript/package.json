{
  "name": "@hostpay/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the HostPay payments API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20"
  },
  "license": "MIT"
}
